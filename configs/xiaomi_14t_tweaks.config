# Xiaomi 14T Pro kernel tweaks fragment
# Applied via merge_config.sh during Kleaf build

# === Networking ===
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_NET_SCH_FQ=y
CONFIG_WIREGUARD=y

# === Filesystem ===
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_NTFS3_FS=y
CONFIG_NTFS3_FS_POSIX_ACL=y
CONFIG_EXFAT_FS=y

# === Memory management ===
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_LRU_GEN_STATS=y
CONFIG_DAMON=y
CONFIG_DAMON_VADDR=y
CONFIG_DAMON_PADDR=y
CONFIG_DAMON_RECLAIM=y

# === Power ===
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_ENERGY_MODEL=y
CONFIG_SCHED_MC=y

# === KPM / KernelSU modules ===
CONFIG_KPM=y

# === ZRAM with ZSTD ===
CONFIG_ZSMALLOC=y
CONFIG_ZRAM=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_ZRAM_DEF_COMP_ZSTD=y
